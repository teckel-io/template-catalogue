        "Not Completed"
      ],
      "question_number": "1",
      "question_text": "Unless at premises where x-ray equipment has previously been used by the practice, notify HSE at least 28 days in advance"
    },
    {
      "answer_options": [
        "Completed",
        "Not Completed"
      ],
      "question_number": "2",
      "question_text": "Consult the RPA about the design of the CBCT facility, including required structural protection and safety and warning devices"
    },
    {
      "answer_options": [
        "Completed",
        "Not Completed"
      ],
      "question_number": "3",
      "question_text": "Ensure all staff radiation protection training is updated for use of the CBCT"
    },
    {
      "answer_options": [
        "Completed",
        "Not Completed"
      ],
      "question_number": "4",
      "question_text": "Have the CBCT \"adequately tested\" before first use and then annually by the MPE/RPA"
    },
    {
      "answer_options": [
        "Completed",
        "Not Completed"
      ],
      "question_number": "5",
      "question_text": "Adopt appropriate referral criteria for CBCT and inform all referrers"
    },
    {
      "answer_options": [
        "Completed",
        "Not Completed"
      ],
      "question_number": "6",
      "question_text": "Review all legal person's IRMER procedures to ensure that they adequately cover the CBCT work, paying particular attention to patient identification, justification and arrangements for the clinical evaluation of images"
    },
    {
      "answer_options": [
        "Completed",
        "Not Completed"
      ],
      "question_number": "7",
      "question_text": "Ensure all practitioners, operators (including those carrying out the clinical evaluation) and referrers have adequate training"
    },
    {
      "answer_options": [
        "Completed",
        "Not Completed"
      ],
      "question_number": "8",
      "question_text": "New equipment must be capable of restricting patient doses to ALARP"
    },
    {
      "answer_options": [
        "Completed",
        "Not Completed"
      ],
      "question_number": "9",
      "question_text": "New equipment must be supplied with suitable software and display screens for clinical imaging"
    },
    {
      "answer_options": [
        "Completed",
        "Not Completed"
      ],
      "question_number": "10",
      "question_text": "New equipment must be supplied with test objects and imaging tools for QA purposes"
    },
    {
      "answer_options": [
        "Completed",
        "Not Completed"
      ],
      "question_number": "11",
      "question_text": "Confirmation that environment suitable for installation of dental CBCT"
    },
    {
      "answer_options": [
        "Completed",
        "Not Completed"
      ],
      "question_number": "12",
      "question_text": "Radiation measurements to confirm adequacy of shielding"
    },
    {
      "answer_options": [
        "Completed",
        "Not Completed"
      ],
      "question_number": "13",
      "question_text": "Installer to undertake adequate testing on behalf of user (especially for General Dental Practices)"
    },
    {
      "answer_options": [
        "Confirmed",
        "Not Confirmed"
      ],
      "question_number": "14",
      "question_text": "Controlled areas will extend throughout the room"
    },
    {
      "answer_options": [
        "Confirmed",
        "Not Confirmed"
      ],
      "question_number": "15",
      "question_text": "Controlled areas will normally exist throughout the working day"
    },
    {
      "answer_options": [
        "Completed",
        "Not Completed"
      ],
      "question_number": "16",
      "question_text": "Local rules must be drafted or reviewed with RPA"
    },
    {
      "answer_options": [
        "Addressed",
        "Not Addressed"
      ],
      "question_number": "17",
      "question_text": "Description of conditions under which controlled area exists requires careful consideration"
    },
    {
      "answer_options": [
        "In Place",
        "Not In Place"
      ],
      "question_number": "18",
      "question_text": "Written arrangements necessary for staff and if patients require support"
    },
    {
      "answer_options": [
        "In Place",
        "Not In Place"
      ],
      "question_number": "19",
      "question_text": "Contingency plans should cover all reasonably foreseeable accidents"
    },
    {
      "answer_options": [
        "Completed",
        "Not Completed"
      ],
      "question_number": "20",
      "question_text": "Radiation measurements must be made at installation and must be repeated at intervals to confirm correct designation"
    },
    {
      "answer_options": [
        "Scheduled",
        "Not Scheduled"
      ],
      "question_number": "21",
      "question_text": "Measurements should be made at least every three years or when conditions change"
    },
    {
      "answer_options": [
        "Understood",
        "Not Understood"
      ],
      "question_number": "22",
      "question_text": "High patient doses as a result of equipment faults - Notifiable to HSE if more than ten times intended value"
    },
    {
      "answer_options": [
        "Completed",
        "Not Completed"
      ],
      "question_number": "23",
      "question_text": "Legal person must ensure suitable persons are identified and entitled to act as Practitioner"
    },
    {
      "answer_options": [
        "Completed",
        "Not Completed"
      ],
      "question_number": "24",
      "question_text": "Legal person must ensure suitable persons are identified and entitled to act as Referrer (including persons at other practices if appropriate)"
    },
    {
      "answer_options": [
        "Completed",
        "Not Completed"
      ],
      "question_number": "25",
      "question_text": "Legal person must ensure suitable persons are identified and entitled to act as Operator (for taking the exposure)"
    },
    {
      "answer_options": [
        "Completed",
        "Not Completed"
      ],
      "question_number": "26",
      "question_text": "Legal person must ensure suitable persons are identified and entitled to act as Operator (for reporting on images, which may include persons at other practices)"
    },
    {
      "answer_options": [
        "Completed",
        "Not Completed"
      ],
      "question_number": "27",
      "question_text": "Legal person must ensure IRMER dutyholders are adequately trained"
    },
    {
      "answer_options": [
        "Followed",
        "Not Followed"
      ],
